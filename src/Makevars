LIBDIR = ./rust/target/release
STATLIB = $(LIBDIR)/libcalamine_r.a
PKG_LIBS = -L$(LIBDIR) -lcalamine_r

all: C_clean

$(SHLIB): $(STATLIB)

$(STATLIB):
	export CARGO_HOME=$(CURDIR)/rust/.cargo && \
	export CARGO_BUILD_JOBS=2 && \
	cargo build --lib --release --offline --manifest-path=./rust/Cargo.toml

C_clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS)

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) rust/target
